# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare build artifacts (config wrangler.jsonc IS committed)
/.wrangler/
/.open-next/
.dev.vars

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but DO commit the no-secrets template so the variable names are documented
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# any nested node_modules (e.g. tooling sub-projects)
**/node_modules/

# ── design & reference material (kept local, not shipped to the repo) ──
# Figma exports, archived/legacy assets, original source SVGs, comps
/design-refs/
# old static HTML wireframes / handoff exports
/streaque-v2/
# Remotion video source project (heavy; the site recreates these natively)
/agent-process-video/
# the Nia app source, dropped in for UI reference only
/NiaCoach-main/
# old marketing-site copy, superseded by app/ + components/
/streaque/
# QA-tooling output (screenshots, reports)
/.gstack/
# source hero images — the site serves the resized copies in public/two-doors/
/student-hero-section.jpg
/faculty-hero-section.jpg

# editor / OS cruft
.vscode/
.idea/
.claude/
*.swp
*~
._*
Thumbs.db

# ── markdown docs — kept LOCAL, never shipped to the repo ──
# Working notes, trackers, audits, the launch checklist, the security packet,
# and the agent-instruction files (CLAUDE.md / AGENTS.md) all stay on disk only.
# If you ever genuinely need a markdown file in the repo, force it: git add -f <file>
*.md
*.markdown

# staff photo source material (originals + tinified) — kept local
/staff pics/
