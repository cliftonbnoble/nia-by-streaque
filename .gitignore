# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare build artifacts (config wrangler.jsonc IS committed)
/.wrangler/
/.open-next/
.dev.vars

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# any nested node_modules (e.g. tooling sub-projects)
**/node_modules/

# ── design & reference material (kept local, not shipped to the repo) ──
# Figma exports, archived/legacy assets, original source SVGs, comps
/design-refs/
# old static HTML wireframes / handoff exports
/streaque-v2/
# Remotion video source project (heavy; the site recreates these natively)
/agent-process-video/
# the Nia app source, dropped in for UI reference only
/NiaCoach-main/

# editor / OS cruft
.vscode/
.idea/
*.swp
*~
._*
Thumbs.db
