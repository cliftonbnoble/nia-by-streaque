# ─────────────────────────────────────────────────────────────────────────────
# Environment variables — TEMPLATE. No real values here; this file IS committed.
#
# The real values are NOT stored in the repo. Set them in the
#   Cloudflare Pages dashboard → Settings → Environment variables
# for BOTH Production and Preview. (See docs/form-wiring-setup.md.)
#
# For local testing only: copy this to `.env.local` (gitignored) and fill it in.
# NEVER commit a file that contains real secret values.
# ─────────────────────────────────────────────────────────────────────────────

# PUBLIC — OPTIONAL. The Turnstile site key is already baked into the code (it's
# public). Set this only to OVERRIDE the baked-in key, e.g. if you rotate keys.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# PUBLIC — canonical site origin used by metadata/sitemap/robots/JSON-LD.
# Defaults to https://streaque.com if unset.
NEXT_PUBLIC_SITE_URL=

# PUBLIC — Cloudflare Web Analytics beacon token (cookieless; no consent banner).
# Dashboard → Web Analytics → your site. Can be hardcoded in app/layout.js instead
# (it's public). Empty = no analytics beacon.
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# SECRET — used only by the Pages Function (functions/api/lead.js). Turnstile
# secret key, for the server-side token verification. Dashboard only.
TURNSTILE_SECRET=

# SECRET — used only by the Pages Function. The Google Apps Script web-app URL
# that appends to the Sheet and emails info@streaque.com. Dashboard only.
LEAD_WEBHOOK_URL=

# SECRET — used only by the Pages Function. Shared secret; must match the
# SHARED_SECRET constant in the Apps Script. Dashboard only.
LEAD_WEBHOOK_SECRET=
